# iyzico Payment Gateway Configuration
# Get your credentials from https://merchant.iyzipay.com

# Sandbox credentials (for testing)
IYZICO_API_KEY=sandbox-xxx
IYZICO_SECRET_KEY=sandbox-xxx
IYZICO_SANDBOX=true

# Production credentials
# IYZICO_API_KEY=your-live-api-key
# IYZICO_SECRET_KEY=your-live-secret-key
# IYZICO_SANDBOX=false

# Site URL (used for iyzico callbacks)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# For Cloudflare Workers, set secrets using:
# npx wrangler secret put IYZICO_API_KEY
# npx wrangler secret put IYZICO_SECRET_KEY
